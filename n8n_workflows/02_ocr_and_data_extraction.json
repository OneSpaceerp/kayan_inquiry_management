              "leftValue": "={{$json.attachments ? Object.keys($json.attachments).length : 0}}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "greaterThan"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
