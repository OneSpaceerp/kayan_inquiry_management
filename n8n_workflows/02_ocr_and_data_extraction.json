        "options": {}
      },
      "id": "cbf82db0-c9a9-40b9-87a3-e29fba9e2ab1",
      "name": "Split Attachments Loop",
      "type": "n8n-nodes-base.itemLists",
      "typeVersion": 3.1,
      "position": [
        500,
        180
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "cond-is-image",
              "leftValue": "={{$json.mimeType}}",
              "rightValue": "image",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "da8f121d-a3df-40be-b4db-ef7eab3c4b93",
      "name": "Is Image File?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        700,
        180
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nfor (const item of items) {\n  if (item.binary && item.binary.attachment) {\n    item.json.base64 = item.binary.attachment.data;\n    item.json.mimeType = item.binary.attachment.mimeType;\n  }\n}\nreturn items;"
      },
      "id": "fe5cbe0c-cbef-49ac-92fe-a8bf327ab3f0",
      "name": "Convert Image to Base64",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        920,
        100
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'google/gemini-2.5-flash:free', messages: [ { role: 'user', content: [ { type: 'text', text: 'Extract all tabular data, line items, lists, and text from this image precisely. Do not summarize or explain.' }, { type: 'image_url', image_url: { url: 'data:' + $json.mimeType + ';base64,' + $json.base64 } } ] } ] } }}"
      },
      "id": "31acdb89-bf8c-4a3d-bcf2-32a10cb23bf3",
      "name": "OpenRouter Image OCR API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1120,
        100
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "openrouter-api-key-id",
          "name": "OpenRouter API Token"
        }
      },
      "retryOnFail": true,
      "maxTries": 5,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    text: $json.choices[0].message.content,\n    filename: $('Split Attachments Loop').first().json.filename || 'image.png'\n  }\n}];"
      },
      "id": "f5acbe23-a1bf-4bdf-84ff-bcfde90a2cfc",
      "name": "Parse Image OCR Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        100
      ]
    },
    {
      "parameters": {
        "operation": "readKey",
        "binaryPropertyName": "attachment",
        "options": {}
      },
      "id": "a9dbf120-cf9c-4932-b2a8-fbe0ab7201bd",
      "name": "Extract Text from Doc Node",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1,
      "position": [
        920,
        260
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{\n  json: {\n    text: $json.text || '',\n    filename: $('Split Attachments Loop').first().json.filename || 'document.pdf'\n  }\n}];"
      },
      "id": "6bf42ea3-88bc-4bc9-a83d-dcf428cbef87",
      "name": "Format Document Text Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        260
      ]
    },
    {
      "parameters": {
        "mode": "combine",
        "combineBy": "position",
        "options": {}
      },
      "id": "ef8cbe2c-bfb0-4da2-bd32-ae0193ca8bee",
      "name": "Merge Extracted Text",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 3,
      "position": [
        1560,
        180
      ]
    },
    {
      "parameters": {
        "jsCode": "const trigger = $('Execute Trigger').first().json;\nlet textBlocks = [];\n\ntry {\n  const merged = $('Merge Extracted Text').all();\n  for (const block of merged) {\n    if (block.json.text) {\n      textBlocks.push(`=== File: ${block.json.filename} ===\\n${block.json.text}`);\n    }\n  }\n} catch(e) {}\n\nreturn [{\n  json: {\n    email_id: trigger.email_id,\n    source_mailbox: trigger.to,\n    from: trigger.from,\n    subject: trigger.subject,\n    body: trigger.body || '',\n    threadId: trigger.threadId || '',\n    attachments: trigger.attachments || [],\n    full_extracted_text: textBlocks.join('\\n\\n')\n  }\n}];"
      },
      "id": "6bf42ea3-88bc-4bc9-a83d-dcf428cbef82",
      "name": "Prepare LLM Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1780,
        280
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ { model: 'google/gemini-2.5-flash:free', messages: [ { role: 'system', content: 'You are an AI assistant that extracts customer details and RFQ items from email and attachment text. Extract the details precisely.\\nReturn ONLY a JSON object containing the following keys:\\n- customer_name (string)\\n- company_name (string)\\n- phone (string)\\n- delivery_location (string)\\n- due_date (string, format YYYY-MM-DD)\\n- tender_number (string)\\n- items (array of objects, each containing: description (string, required), quantity (number), uom (string))' }, { role: 'user', content: 'Email Subject: ' + ($json.subject || '') + '\\nFrom: ' + ($json.from || '') + '\\nBody: ' + ($json.body || '') + '\\n\\n--- Extracted Document Text ---\\n' + ($json.full_extracted_text || '') } ], response_format: { type: 'json_object' } } }}"
      },
      "id": "83fa0cb2-fb3d-4c3e-8b1e-abcf874acbef",
      "name": "Extract Metadata and Items OpenRouter API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2000,
        280
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "openrouter-api-key-id",
          "name": "OpenRouter API Token"
        }
      },
      "retryOnFail": true,
      "maxTries": 5,
      "waitBetweenTries": 5000
    },
    {
      "parameters": {
        "jsCode": "let responseText = $json.choices[0].message.content.trim();\nif (responseText.startsWith('```')) {\n  responseText = responseText.replace(/^```json\\s*/i, '').replace(/```$/, '').trim();\n}\nconst parsed = JSON.parse(responseText);\nconst payload = $('Prepare LLM Payload').first().json;\n\nreturn [{\n  json: {\n    email_id: payload.email_id,\n    source_mailbox: payload.source_mailbox,\n    from: payload.from,\n    subject: payload.subject,\n    threadId: payload.threadId || '',\n    attachments: payload.attachments || [],\n    customer_name: parsed.customer_name || '',\n    company_name: parsed.company_name || '',\n    phone: parsed.phone || '',\n    delivery_location: parsed.delivery_location || '',\n    due_date: parsed.due_date || '',\n    tender_number: parsed.tender_number || '',\n    items: parsed.items || []\n  }\n}];"
      },
      "id": "83cf0cb2-fb4d-4d3e-8b2e-abcd874bcbef",
      "name": "Parse Extraction Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2200,
        280
      ]
    },
    {
      "parameters": {
        "workflowId": "03_customer_matching_and_ticket_creation",
        "mode": "wait",
        "options": {}
      },
