      "parameters": {
        "jsCode": "let responseText = $json.choices[0].message.content.trim();\nif (responseText.startsWith('```')) {\n  responseText = responseText.replace(/^```json\\s*/i, '').replace(/```$/, '').trim();\n}\nconst parsed = JSON.parse(responseText);\nconst trigger = $('IMAP Email Trigger').first().json;\nconst settings = $('Get Inquiry Settings').first().json.message || {};\n\n// Determine which AI provider/model was used\nlet aiProvider = settings.default_ai_provider || 'OpenRouter';\nlet aiModel = '';\ntry {\n  aiModel = $json.model || '';\n} catch(e) {}\n\nreturn [{\n  json: {\n    email_id: trigger.messageId,\n    to: trigger.to?.value?.[0]?.address || '',\n    from: trigger.from?.value?.[0]?.address || '',\n    subject: trigger.subject,\n    body: trigger.text || '',\n    html_body: trigger.html || '',\n    threadId: trigger.threadId || '',\n    date: trigger.date || '',\n    classification: parsed.classification,\n    confidence: parsed.confidence,\n    reason: parsed.reason,\n    ai_provider: aiProvider,\n    ai_model: aiModel\n  }\n}];"
      },
