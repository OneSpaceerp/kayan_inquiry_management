        "jsCode": "const classifyOutput = $('Parse AI Output').first().json;\nlet textBlocks = [];\n\n// Collect all extracted text blocks from merged output\nconst merged = $input.all();\nfor (const block of merged) {\n  if (block.json && block.json.text) {\n    textBlocks.push('=== File: ' + (block.json.filename || 'unknown') + ' ===\\n' + block.json.text);\n  }\n}\n\nreturn [{\n  json: {\n    email_id: classifyOutput.email_id,\n    source_mailbox: classifyOutput.to,\n    from: classifyOutput.from,\n    subject: classifyOutput.subject,\n    body: classifyOutput.body || '',\n    date: classifyOutput.date || '',\n    threadId: classifyOutput.threadId || '',\n    classification: classifyOutput.classification,\n    confidence: classifyOutput.confidence,\n    ai_provider: classifyOutput.ai_provider,\n    ai_model: classifyOutput.ai_model,\n    full_extracted_text: textBlocks.join('\\n\\n')\n  }\n}];"
      },
