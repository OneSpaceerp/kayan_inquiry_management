      "id": "31b26ae3-02f8-4100-abef-ffde122a2bc4",
      "name": "Query Active Tickets API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        320,
        280
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "erpnext-api-token-id",
          "name": "ERPNext API Token Credentials"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const now = new Date();\nconst breachedTickets = [];\nconst tickets = $json.data || [];\n\nfor (const t of tickets) {\n  let isBreached = false;\n  let breachType = \"\";\n  let deadline = null;\n\n  if ([\"New\", \"Pending Review\"].includes(t.status) && t.sla_assignment_deadline) {\n    deadline = new Date(t.sla_assignment_deadline);\n    if (now > deadline) {\n      isBreached = true;\n      breachType = \"Assignment SLA\";\n    }\n  } else if ([\"Assigned to Sales Engineer\", \"Assigned to Application Engineer\", \"Technical Review In Progress\"].includes(t.status) && t.sla_technical_deadline) {\n    deadline = new Date(t.sla_technical_deadline);\n    if (now > deadline) {\n      isBreached = true;\n      breachType = \"Technical Review SLA\";\n    }\n  } else if (t.status === \"Quotation Preparation In Progress\" && t.sla_quotation_deadline) {\n    deadline = new Date(t.sla_quotation_deadline);\n    if (now > deadline) {\n      isBreached = true;\n      breachType = \"Quotation Preparation SLA\";\n    }\n  }\n\n  if (isBreached) {\n    breachedTickets.push({\n      json: {\n        name: t.name,\n        status: t.status,\n        breach_type: breachType,\n        deadline: deadline.toISOString(),\n        sales_engineer: t.sales_engineer,\n        company: t.company\n      }\n    });\n  }\n}\n\nreturn breachedTickets;"
      },
      "id": "6bf42ea3-88bc-4bc9-a83d-dcf428cbef84",
