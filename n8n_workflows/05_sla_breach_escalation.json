              "name": "filters",
              "value": "=[[\"Inquiry Ticket\", \"status\", \"not in\", [\"Won\", \"Lost\", \"Cancelled\", \"Approved\", \"Quotation Sent\"]], [\"Inquiry Ticket\", \"sla_status\", \"in\", [\"Active\", \"Not Started\"]]]"
            },
            {
              "name": "fields",
              "value": "[\"name\", \"status\", \"sla_status\", \"sla_assignment_deadline\", \"sla_technical_deadline\", \"sla_quotation_deadline\", \"sales_engineer\", \"company\"]"
            }
          ]
        },
        "options": {}
