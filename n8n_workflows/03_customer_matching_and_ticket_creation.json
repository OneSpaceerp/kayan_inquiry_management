    {
      "parameters": {
        "jsCode": "const trigger = $('Execute Trigger').first().json;\nlet customer = \"\";\nlet lead = \"\";\nlet opportunity = \"\";\n\n// Fix: Handle Frappe API response envelope (message wrapper)\ntry {\n  const customerOpp = $('Create Opportunity for Customer').first();\n  if (customerOpp) {\n    const d = customerOpp.json.message || customerOpp.json.data || customerOpp.json;\n    opportunity = d.name || '';\n    customer = d.party_name || '';\n  }\n} catch(e) { /* Customer path not taken */ }\n\ntry {\n  const leadOpp = $('Create Opportunity for Lead API').first();\n  if (leadOpp) {\n    const d = leadOpp.json.message || leadOpp.json.data || leadOpp.json;\n    opportunity = d.name || '';\n    lead = d.party_name || '';\n  }\n} catch(e) { /* Lead path not taken */ }\n\nconst formattedItems = (trigger.items || []).map(item => ({\n  item_description: item.description,\n  quantity: item.quantity,\n  uom: item.uom || 'Nos'\n}));\n\n// Use classification from upstream if available, fallback to RFQ\nconst inquiryType = trigger.classification || 'RFQ';\n\nreturn [{\n  json: {\n    inquiry_type: inquiryType,\n    customer: customer || null,\n    lead: lead || null,\n    opportunity: opportunity || null,\n    company_name: trigger.company_name || '',\n    contact_person: trigger.customer_name || '',\n    contact_phone: trigger.phone || '',\n    contact_email: trigger.from || '',\n    delivery_location: trigger.delivery_location || '',\n    due_date: trigger.due_date || '',\n    tender_number: trigger.tender_number || '',\n    source_mailbox: trigger.source_mailbox || '',\n    original_email_subject: trigger.subject || '',\n    received_date: trigger.date || '',\n    ai_classification: trigger.classification || '',\n    ai_confidence: trigger.confidence || 0,\n    ai_provider: trigger.ai_provider || '',\n    status: 'New',\n    line_items: formattedItems,\n    attachments: trigger.attachments || []\n  }\n}];"
      },
