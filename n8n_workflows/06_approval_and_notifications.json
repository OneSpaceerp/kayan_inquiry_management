        "jsonBody": "={\n  \"inquiry\": \"{{$('Set Ticket Approved API').first().json.inquiry}}\",\n  \"type\": \"Email\",\n  \"recipient\": \"{{$('Check Next Level').first().json.sales_engineer}}\",\n  \"template\": \"quotation_approved_and_generated\"\n}",
        "options": {}
